inference.getplexo.com {
  reverse_proxy inference-gateway-gateway-1:3001

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    -Server
  }

  encode gzip zstd
}

gateway-admin.getplexo.com {
  reverse_proxy inference-gateway-admin-1:3002

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    -Server
  }

  encode gzip zstd
}

{$PUBLIC_DOMAIN} {
  # SSE — disable buffering (must be before generic /api/* catch)
  handle /api/sse {
    reverse_proxy api:3001 {
      flush_interval -1
    }
  }

  # Auth.js callback routes — served by web
  handle /api/auth/* {
    reverse_proxy web:3000
  }

  # API backend
  handle /api/* {
    reverse_proxy api:3001
  }
  handle /health {
    reverse_proxy api:3001
  }

  # Dashboard — catch-all (must be last)
  handle {
    reverse_proxy web:3000
  }

  # Security headers
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-XSS-Protection "1; mode=block"
    -Server
  }

  # Compress
  encode gzip zstd
}
