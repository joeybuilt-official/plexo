FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@latest --activate

# ── Resolve git commit hash ──────────────────────────────────────────────────
FROM alpine:3.20 AS git-meta
ARG SOURCE_COMMIT=unknown
WORKDIR /meta
COPY .gi[t] /meta/git
COPY .source-commit-overrid[e] /meta/
RUN SC="${SOURCE_COMMIT}"; \
    if [ "$SC" = "unknown" ] && [ -f /meta/.source-commit-override ]; then \
      SC=$(cat /meta/.source-commit-override); \
    fi; \
    if [ "$SC" = "unknown" ] && [ -f /meta/git/HEAD ]; then \
      REF=$(cat /meta/git/HEAD); \
      case "$REF" in \
        ref:*) RPATH=$(echo "$REF" | sed 's/^ref: *//'); \
               if [ -f "/meta/git/$RPATH" ]; then SC=$(cat "/meta/git/$RPATH"); \
               elif [ -f /meta/git/packed-refs ]; then SC=$(grep " $RPATH" /meta/git/packed-refs | head -1 | cut -d' ' -f1); fi ;; \
        *) SC="$REF" ;; \
      esac; \
    fi; \
    echo "${SC:-unknown}" > /meta/SOURCE_COMMIT

FROM base AS deps
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY packages/ui/package.json packages/ui/
COPY packages/logger/package.json packages/logger/
COPY packages/db/package.json packages/db/
COPY packages/agent/package.json packages/agent/
COPY packages/queue/package.json packages/queue/
COPY packages/sdk/package.json packages/sdk/
COPY packages/storage/package.json packages/storage/

RUN pnpm install --frozen-lockfile --filter @plexo/web...

FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/ui/node_modules ./packages/ui/node_modules
COPY --from=deps /app/packages/logger/node_modules ./packages/logger/node_modules
COPY --from=deps /app/packages/db/node_modules ./packages/db/node_modules
COPY tsconfig.base.json ./
COPY apps/web ./apps/web
COPY packages/ui ./packages/ui
COPY packages/logger ./packages/logger
COPY packages/db ./packages/db
COPY --from=git-meta /meta/SOURCE_COMMIT /tmp/SOURCE_COMMIT
ENV NEXT_PUBLIC_SOURCE_COMMIT=""
# INTERNAL_API_URL must be available at build time for Next.js rewrites
# (rewrites are baked into the build output, not resolved at runtime)
ARG INTERNAL_API_URL=http://api:3001
ENV INTERNAL_API_URL=${INTERNAL_API_URL}
# Supabase Auth URL/key must be available at build time for Next.js NEXT_PUBLIC_ inlining
ARG NEXT_PUBLIC_SUPABASE_AUTH_URL
ARG NEXT_PUBLIC_SUPABASE_AUTH_ANON_KEY
ENV NEXT_PUBLIC_SUPABASE_AUTH_URL=${NEXT_PUBLIC_SUPABASE_AUTH_URL}
ENV NEXT_PUBLIC_SUPABASE_AUTH_ANON_KEY=${NEXT_PUBLIC_SUPABASE_AUTH_ANON_KEY}
RUN export NEXT_PUBLIC_SOURCE_COMMIT=$(cat /tmp/SOURCE_COMMIT) && pnpm --filter @plexo/web build

FROM node:22-alpine AS runner
WORKDIR /app
RUN addgroup --system --gid 1001 plexo && \
    adduser --system --uid 1001 --ingroup plexo plexo
COPY --from=builder --chown=plexo:plexo /app/apps/web/.next/standalone ./
COPY --from=builder --chown=plexo:plexo /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=plexo:plexo /app/apps/web/public ./apps/web/public
USER plexo
EXPOSE 3000
ENV HOSTNAME=0.0.0.0
CMD ["node", "apps/web/server.js"]
