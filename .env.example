# =============================================================================
# Plexo — Environment Configuration Example
#
# DO NOT fill this file in directly.
# Run the install script instead — it generates all secrets automatically:
#
#   bash scripts/install.sh --domain=plexo.yourdomain.com
#
# To configure manually: copy this file to .env and fill in the values.
# Generate secrets with:  openssl rand -hex 32
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Database credentials — REQUIRED. Postgres will not accept connections without these.
# POSTGRES_USER is fixed to 'plexo' (set in docker/compose.yml — do not override unless using external Postgres).
# POSTGRES_PASSWORD must be set. Generate one: openssl rand -hex 32
POSTGRES_PASSWORD=


# Public URL including protocol (used for OAuth callbacks, links in messages)
PUBLIC_URL=https://plexo.yourdomain.com

# Domain without protocol (used for Caddy TLS, CORS)
PUBLIC_DOMAIN=plexo.yourdomain.com

# Session encryption secret
# Generate: openssl rand -hex 64
SESSION_SECRET=

# AES-256-GCM key for encrypting AI provider credentials at rest
# Generate: openssl rand -hex 32
ENCRYPTION_SECRET=

# ── Supabase Auth (shared Joeybuilt platform) ─────────────────────────────────
# JWT secret from the shared Supabase instance (used by the API to validate tokens)
SUPABASE_JWT_SECRET=
# Public Supabase URL (used by the web app login form)
# NEXT_PUBLIC_SUPABASE_AUTH_URL=https://platform.joeybuilt.com
# Supabase anon key (public, inlined into the web build)
# NEXT_PUBLIC_SUPABASE_AUTH_ANON_KEY=
# Service role key (server-side only, for admin operations)
# SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers (configure in-app via Settings → AI Providers) ───────────────
# These env vars are optional — use them to pre-seed a provider without UI setup.
# Keys entered in the UI are encrypted at rest via ENCRYPTION_SECRET.

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=

# Groq — console.groq.com
GROQ_API_KEY=

# Mistral — console.mistral.ai
MISTRAL_API_KEY=

# ── GitHub OAuth (enables GitHub login + GitHub Actions connection) ────────────

# Create at: github.com/settings/applications/new
# Callback URL: ${PUBLIC_URL}/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Slack (enables Slack channel integration) ─────────────────────────────────

# Create at: api.slack.com/apps → OAuth & Permissions
# Redirect URL: ${PUBLIC_URL}/api/oauth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Google OAuth (enables Google Drive connection) ────────────────────────────

# Create at: console.cloud.google.com → Credentials → OAuth 2.0 Client
# Redirect URL: ${PUBLIC_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram (enables Telegram channel) ──────────────────────────────────────

# Get from @BotFather on Telegram
# Set webhook: ${PUBLIC_URL}/api/telegram/webhook
TELEGRAM_BOT_TOKEN=

# ── Discord (enables Discord slash commands) ──────────────────────────────────

# Create at: discord.com/developers/applications
# Add interactions endpoint: ${PUBLIC_URL}/api/discord/interactions
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# ── Cost Controls ─────────────────────────────────────────────────────────────

# Tasks auto-pause when weekly AI spend reaches this amount
API_COST_CEILING_USD=10.00

# ── Sprint Engine ─────────────────────────────────────────────────────────────

# Max concurrent sprint workers (reduce if VPS memory is constrained)
MAX_SPRINT_WORKERS=5

# ── Asset Storage (auto-configured by Docker Compose + install.sh) ────────────

# Access key / bucket user (auto-generated; must match MINIO_ROOT_USER)
STORAGE_ACCESS_KEY=plexo
# Secret key (auto-generated by install.sh — never commit this)
# Generate: openssl rand -hex 32
STORAGE_SECRET_KEY=
STORAGE_BUCKET=plexo-assets
# Uncomment to use external S3 / Cloudflare R2 / Backblaze B2:
# STORAGE_ENDPOINT=https://s3.amazonaws.com

# ── Voice (Deepgram) ──────────────────────────────────────────────────────────

# deepgram.com — enables transcription + voice synthesis
DEEPGRAM_API_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────

POSTHOG_API_KEY=

# Sentry DSN for error reporting
SENTRY_DSN=

# Sentry Webhook Secret for tasks on new issues
SENTRY_WEBHOOK_SECRET=

# ── Instance ──────────────────────────────────────────────────────────────────

# Unique ID for this Plexo instance (auto-generated by install.sh)
PLEXO_INSTANCE_ID=

# ── Database (auto-configured by Docker Compose) ──────────────────────────────

# Only override if running Postgres outside Docker Compose
# DATABASE_URL=postgresql://plexo:${POSTGRES_PASSWORD}@localhost:5432/plexo

# ── Redis (auto-configured by Docker Compose) ─────────────────────────────────

# Only override if running Redis outside Docker Compose
# REDIS_URL=redis://localhost:6379

# ── Supabase Auth (build-time for web container) ──────────────
# These are baked into the Next.js client bundle at build time.
# Must match the platform Supabase instance.
NEXT_PUBLIC_SUPABASE_AUTH_URL=https://platform.joeybuilt.com
NEXT_PUBLIC_SUPABASE_AUTH_ANON_KEY=

# ── Super Admin ───────────────────────────────────────────────
# Comma-separated list of emails that get auto-promoted to super admin
SUPER_ADMIN_EMAILS=
