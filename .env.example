# ─────────────────────────────────────────────────────────────────────────────
# Plexo — Environment Configuration
# Copy to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Database password for PostgreSQL
# Generate: openssl rand -hex 32
POSTGRES_PASSWORD=

# Public URL including protocol (used for OAuth callbacks, links in messages)
PUBLIC_URL=https://plexo.yourdomain.com

# Domain without protocol (used for Caddy TLS, CORS)
PUBLIC_DOMAIN=plexo.yourdomain.com

# Session encryption secret
# Generate: openssl rand -hex 64
SESSION_SECRET=

# AES-256-GCM key for encrypting AI provider credentials at rest
# Generate: openssl rand -hex 32
ENCRYPTION_SECRET=

# ── AI Providers (at least one required for agent tasks) ──────────────────────

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=

# Groq — console.groq.com
GROQ_API_KEY=

# Mistral — console.mistral.ai
MISTRAL_API_KEY=

# ── GitHub OAuth (enables GitHub login + GitHub Actions connection) ────────────

# Create at: github.com/settings/applications/new
# Callback URL: ${PUBLIC_URL}/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Slack (enables Slack channel integration) ─────────────────────────────────

# Create at: api.slack.com/apps → OAuth & Permissions
# Redirect URL: ${PUBLIC_URL}/api/oauth/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Google OAuth (enables Google Drive connection) ────────────────────────────

# Create at: console.cloud.google.com → Credentials → OAuth 2.0 Client
# Redirect URL: ${PUBLIC_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram (enables Telegram channel) ──────────────────────────────────────

# Get from @BotFather on Telegram
# Set webhook: ${PUBLIC_URL}/api/telegram/webhook
TELEGRAM_BOT_TOKEN=

# ── Discord (enables Discord slash commands) ──────────────────────────────────

# Create at: discord.com/developers/applications
# Add interactions endpoint: ${PUBLIC_URL}/api/discord/interactions
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# ── Cost Controls ─────────────────────────────────────────────────────────────

# Tasks auto-pause when weekly AI spend reaches this amount
API_COST_CEILING_USD=10.00

# ── Sprint Engine ─────────────────────────────────────────────────────────────

# Max concurrent sprint workers (reduce if VPS memory is constrained)
MAX_SPRINT_WORKERS=5

# ── Database (auto-configured by Docker Compose) ──────────────────────────────

# Only override if running Postgres outside Docker Compose
# DATABASE_URL=postgresql://plexo:${POSTGRES_PASSWORD}@localhost:5432/plexo

# ── Redis (auto-configured by Docker Compose) ─────────────────────────────────

# Only override if running Redis outside Docker Compose
# REDIS_URL=redis://localhost:6379
