# Server
GATEWAY_PORT=3001
ADMIN_PORT=3002
NODE_ENV=production
GATEWAY_URL=https://your-gateway.example.com
ADMIN_URL=https://your-admin.example.com

# Admin auth (Auth.js)
# AUTH_URL is injected automatically from ADMIN_URL in docker-compose.yml — do not set separately.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Database (shared by gateway and admin)
# DATABASE_URL is constructed from POSTGRES_PASSWORD in docker-compose.yml — do not set separately.
POSTGRES_PASSWORD=

# Cache (gateway only)
VALKEY_URL=redis://valkey:6379

# Upstream provider keys (Plexo's own — never exposed to instances)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=

# Anomaly alerting
ANOMALY_WEBHOOK_URL=
ANOMALY_WEBHOOK_SECRET=

# Signing
# Generate with: openssl rand -hex 32
SIGNING_PEPPER=

# Analytics (PostHog)
POSTHOG_API_KEY=
POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
